{
  "name": "clove",
  "version": "0.0.7",
  "description": "Orchestrator for running multiple AI coding agents with streaming and interactive input",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clove": "bin/clove.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/cli.ts daemon --foreground",
    "dev:cli": "bun run src/cli.ts",
    "start": "bun run bin/clove.js",
    "build:binary": "bun run build && bun run dashboard:build && bun build src/cli.ts --compile --outfile dist/clove-macos-arm64 && mkdir -p dist/dashboard/dist && cp -r dashboard/dist/. dist/dashboard/dist/ && (uname -s | grep -q Darwin && (codesign -s - --force dist/clove-macos-arm64 && xattr -cr dist/clove-macos-arm64) || true) && ./scripts/zip-for-release.sh",
    "release": "./scripts/release.sh",
    "sign:macos": "./scripts/sign-and-notarize-macos.sh",
    "lint": "eslint src dashboard/src",
    "lint:fix": "eslint src dashboard/src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard:dev": "cd dashboard && bun run dev",
    "dashboard:build": "cd dashboard && bun run build",
    "dashboard:preview": "cd dashboard && bun run preview"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "keywords": [
    "agents",
    "orchestrator",
    "coding",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "kysely": "^0.28.14",
    "unique-names-generator": "^4.7.1"
  }
}
