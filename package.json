{
  "name": "clove",
  "version": "0.1.0",
  "description": "Orchestrator for running multiple AI coding agents with streaming and interactive input",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clove": "bin/clove.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node bin/clove.js",
    "build:binary": "npm run build && npm run dashboard:build && pkg . --targets node18-macos-arm64 --output dist/clove-macos-arm64 --no-bytecode",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard:dev": "npm run dev --prefix dashboard",
    "dashboard:build": "npm run build --prefix dashboard",
    "dashboard:preview": "npm run preview --prefix dashboard"
  },
  "pkg": {
    "scripts": ["bin/clove.js", "dist/**/*.js"],
    "assets": ["dashboard/dist/**"],
    "targets": ["node18-macos-arm64"]
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agents",
    "orchestrator",
    "coding",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@yao-pkg/pkg": "^6.0.0",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "unique-names-generator": "^4.7.1"
  }
}
